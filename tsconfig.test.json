{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": null
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "bin/**/*.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts",
    "test/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "coverage"]
}
